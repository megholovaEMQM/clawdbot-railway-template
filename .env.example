# ─────────────────────────────────────────────
# Core (required)
# ─────────────────────────────────────────────
SETUP_PASSWORD=                     # Protects the /setup UI
JWT_SECRET=                         # Signs JWTs for the agent API
OPENCLAW_GATEWAY_TOKEN=             # Bearer token for the openclaw gateway

# ─────────────────────────────────────────────
# Storage paths (set automatically on Railway via railway.toml)
# ─────────────────────────────────────────────
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ─────────────────────────────────────────────
# Orchestrator integration (required for multi-tenant setup)
# ─────────────────────────────────────────────
ORCHESTRATOR_URL=                   # Public URL of the orchestrator (e.g. https://orchestrator.up.railway.app)
ORCHESTRATOR_SECRET=                # Shared secret for orchestrator callbacks
TENANT_ID=                          # Set automatically by the orchestrator during provisioning

# ─────────────────────────────────────────────
# Auto-setup (set automatically by the orchestrator during provisioning)
# ─────────────────────────────────────────────
OPENCLAW_AUTO_SETUP=                # Set to "true" to skip the setup UI and auto-configure on first boot
OPENCLAW_AUTH_CHOICE=               # Auth provider (e.g. apiKey, openai-api-key, gemini-api-key)
OPENCLAW_AUTH_SECRET=               # API key for the chosen auth provider
OPENCLAW_FLOW=quickstart            # Onboarding flow (default: quickstart)
OPENCLAW_DEFAULT_MODEL=             # Default model for all agents (e.g. claude-sonnet-4-5)

# ─────────────────────────────────────────────
# Channel tokens (optional, set during provisioning if needed)
# ─────────────────────────────────────────────
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_DISCORD_TOKEN=
OPENCLAW_SLACK_BOT_TOKEN=
OPENCLAW_SLACK_APP_TOKEN=

# ─────────────────────────────────────────────
# Injected automatically by Railway — do not set manually
# ─────────────────────────────────────────────
# PORT
# RAILWAY_PUBLIC_DOMAIN
# RAILWAY_GIT_COMMIT_SHA
